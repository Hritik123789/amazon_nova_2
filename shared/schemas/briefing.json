{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Briefing",
  "description": "Schema for voice briefing data",
  "type": "object",
  "properties": {
    "briefing_id": {
      "type": "string",
      "description": "Unique briefing identifier"
    },
    "user_id": {
      "type": "string",
      "description": "User identifier for whom the briefing was generated"
    },
    "text_content": {
      "type": "string",
      "description": "Full text transcript of the briefing"
    },
    "audio_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the audio file in S3"
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Duration of the audio briefing in seconds"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["permits", "social", "news", "alerts", "weather"],
            "description": "Type of briefing section"
          },
          "summary": {
            "type": "string",
            "description": "Brief summary of this section"
          },
          "items_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of items in this section"
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Priority level of this section"
          }
        },
        "required": ["type", "summary", "items_count", "priority"]
      },
      "description": "Array of briefing sections"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the briefing was generated (ISO8601 format)"
    }
  },
  "required": ["briefing_id", "user_id", "text_content", "audio_url", "duration_seconds", "sections", "generated_at"]
}
